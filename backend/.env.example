# ============================================================
# buddy-app — backend/.env (backend-only local dev, no Docker)
# ============================================================
# Copy this file to backend/.env and fill in the values.
# When running via Docker Compose, use the root .env instead — this file is ignored there.
# ============================================================

# ------------------------------------------------------------
# Database
# Option A (recommended for local dev): single SQLite URL
# Option B: discrete Postgres vars (comment out DATABASE_URL and uncomment below)
# ------------------------------------------------------------
DATABASE_URL=sqlite:///./buddy360.db

# Option B — Postgres:
# DATABASE_URL=postgresql+psycopg://buddy360:buddy360_dev@localhost:5432/buddy360
# Or use discrete vars (omit DATABASE_URL if using these):
# POSTGRES_HOST=localhost                                      # local dev without Docker
# POSTGRES_HOST=buddy360.xxxxxxxxxxxx.eu-west-1.rds.amazonaws.com  # AWS deployment
# POSTGRES_PORT=5432
# POSTGRES_USER=buddy360
# POSTGRES_PASSWORD=buddy360_dev
# POSTGRES_DB=buddy360

# DB connection pool (tune for your instance size)
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10

# ------------------------------------------------------------
# JWT — required
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Use 64+ hex chars in production.
# ------------------------------------------------------------
JWT_SECRET=
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_HOURS=24

# ------------------------------------------------------------
# LLM providers — set at least one key to enable LLM features.
# Auto-selection priority (first key found wins): OpenAI → Anthropic → Gemini.
# Callers can pin a provider with the `provider` field in POST /api/v1/llm/invoke.
# ------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Max seconds to wait for an LLM response before timing out
LLM_TIMEOUT_SECONDS=60

# Max LLM calls per user per hour (Redis sliding window, or in-memory if no Redis).
LLM_HOURLY_LIMIT=200

# ------------------------------------------------------------
# Google Sign-In — OAuth 2.0 Web client ID
# Leave empty to disable POST /auth/google.
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=

# ------------------------------------------------------------
# Redis — LLM rate limiter
# Leave blank for local dev — falls back to in-process rate limiting automatically.
# Set to redis://localhost:6379 if you have Redis running locally.
# ------------------------------------------------------------
# REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------
# CORS — allowed browser origins (comma-separated, no spaces, no trailing slash)
# ------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080

# ------------------------------------------------------------
# Cookie security for auth tokens
# COOKIE_SECURE   — false for local HTTP dev; true in production (HTTPS required).
# COOKIE_SAMESITE — lax suits most SPAs.
# COOKIE_DOMAIN   — leave empty for localhost.
# ------------------------------------------------------------
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# ------------------------------------------------------------
# Application environment
# APP_ENV     — local | prod
# BEHIND_PROXY — true if behind a reverse proxy (reads X-Forwarded-For for rate limiting)
# ------------------------------------------------------------
APP_ENV=local
BEHIND_PROXY=false

# ------------------------------------------------------------
# Multi-region routing (optional — omit for single-instance / local dev)
# ROUTER_DB_URL    — Global Router DB (email_hash → region). Falls back to DATABASE_URL.
# REGIONAL_DB_URLS — JSON map of region → DB URL. Falls back to DATABASE_URL.
# DEFAULT_REGION   — Region when no JWT present. Use "local" for single-instance.
# ------------------------------------------------------------
DEFAULT_REGION=local
# ROUTER_DB_URL=postgresql+psycopg://user:pass@router-db-host:5432/buddy_router
# REGIONAL_DB_URLS={"eu":"postgresql+psycopg://...","us":"postgresql+psycopg://..."}

# Aurora Global Database (multi-region) — skip migrations on read-only replicas.
# Set these to any non-empty value in secondary-region deployments.
# REGIONAL_DB_SKIP_MIGRATION=
# ROUTER_DB_URL_SKIP_MIGRATION=

# ------------------------------------------------------------
# Background reconciler — repairs stale saga writes
# How often (minutes) to scan user_regions for 'pending' rows older than 10 min.
# ------------------------------------------------------------
RECONCILER_INTERVAL_MINUTES=5

# ============================================================
# buddy-app — backend/.env (backend-only local dev, no Docker)
# ============================================================
# Copy this file to backend/.env and fill in the values.
# When running via Docker Compose, use the root .env instead — this file is ignored there.
# ============================================================

# ------------------------------------------------------------
# MongoDB
# Local dev (no Atlas): mongodb://localhost:27017
# Atlas:                mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# ------------------------------------------------------------
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=buddy360-local

# Atlas zone / location used as default when no JWT is present.
DEFAULT_LOCATION=us

# ------------------------------------------------------------
# JWT — required
# Generate a 2048-bit RSA key pair and format for this .env file:
#
#   openssl genrsa -out jwt_private.pem 2048
#   awk 'NF {sub(/\r/,""); printf "%s\\n",$0}' jwt_private.pem
#
# Paste the single-line output as the value of JWT_PRIVATE_KEY below.
# The \n escapes are converted back to real newlines by the backend at startup.
# For backend-only dev (no Docker), you can also paste the raw multiline PEM directly.
#
# To derive the public key (required as JWT_PUBLIC_KEYS GitHub secret for
# the infra-live-edge Terraform workflow):
#
#   openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
#   awk 'NF {sub(/\r/,""); printf "%s\\n",$0}' jwt_public.pem
#
# Store as a JSON map in the JWT_PUBLIC_KEYS GitHub secret:
#   {"key-v1": "<single-line output from awk above>"}
#
# See docs/jwt-keys.md for the full setup and key rotation procedure.
# ------------------------------------------------------------
JWT_PRIVATE_KEY=
JWT_KEY_ID=key-v1
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_HOURS=24

# ------------------------------------------------------------
# LLM providers — set at least one key to enable LLM features.
# Auto-selection priority (first key found wins): OpenAI → Anthropic → Gemini.
# Callers can pin a provider with the `provider` field in POST /api/v1/llm/invoke.
# ------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash

LLM_TIMEOUT_SECONDS=60
LLM_HOURLY_LIMIT=200

# ------------------------------------------------------------
# Google Sign-In — OAuth 2.0 Web client ID
# Leave empty to disable POST /auth/google.
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=

# ------------------------------------------------------------
# Redis — LLM rate limiter
# Leave blank for local dev — falls back to in-process rate limiting automatically.
# Set to redis://localhost:6379 if you have Redis running locally.
#
# REDIS_AUTH_TOKEN — only required when connecting to an AUTH-protected Redis
# (staging/prod ElastiCache). Leave empty for local dev (no auth).
# ------------------------------------------------------------
# REDIS_URL=redis://localhost:6379
# REDIS_AUTH_TOKEN=

# ------------------------------------------------------------
# CORS — allowed browser origins (comma-separated, no spaces, no trailing slash)
# ------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080

# ------------------------------------------------------------
# Cookie security for auth tokens
# COOKIE_SECURE   — false for local HTTP dev; true in production (HTTPS required).
# COOKIE_SAMESITE — lax suits most SPAs.
# COOKIE_DOMAIN   — leave empty for localhost.
# ------------------------------------------------------------
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# ------------------------------------------------------------
# Application environment
# APP_ENV     — local | prod
# BEHIND_PROXY — true if behind a reverse proxy (reads X-Forwarded-For for rate limiting)
# ------------------------------------------------------------
APP_ENV=local
BEHIND_PROXY=false

# ------------------------------------------------------------
# S3 — backend assets bucket
# Pre-existing bucket that holds static assets under the app-assets/ prefix.
# Served in production via CloudFront /app-assets/*.
# ------------------------------------------------------------
ASSETS_BUCKET_NAME=person-local-assets-bucket

JWT_SECRET=use-a-long-random-secret-in-production
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# DB: explicit URL (recommended for simple local SQLite):
DATABASE_URL=sqlite:///./buddy360.db

# Or Docker Compose Postgres (omit DATABASE_URL); set discrete vars instead:
# POSTGRES_HOST=db
# POSTGRES_PORT=5432
# POSTGRES_USER=buddy360
# POSTGRES_PASSWORD=buddy360_dev
# POSTGRES_DB=buddy360

# Comma-separated allowed browser origins (must match how you open the UI, no spaces):
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080

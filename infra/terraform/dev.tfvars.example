# -- Supplied via GitHub Actions workflow inputs -------------------------------
# aws_region          -> workflow input
# environment         -> workflow input
#
# -- Supplied via GitHub Actions secrets (do not set here) --------------------
# domain_name         -> secret: DOMAIN_NAME
# subdomain           -> secret: SUBDOMAIN
# hosted_zone_id      -> secret: HOSTED_ZONE_ID
# acm_certificate_arn -> secret: ACM_CERTIFICATE_ARN
#
# -- Passed at terraform init / apply (not set in this file) ------------------
# db_state_key is a required variable with no default. Supply it via:
#   CI:    TF_VAR_db_state_key env var (set automatically by terraform.yml)
#   Local: terraform apply -var="db_state_key=terraform-state-files/buddy360/dev/db/ap-south-1/terraform.tfstate"

# -- General ------------------------------------------------------------------
app_name = "buddy360"

# -- EC2 ----------------------------------------------------------------------
instance_type    = "t3.small"
allowed_ssh_cidr = "1.2.3.4/32" # replace with your actual IP
# key_name       = "my-key-pair"  # optional  -  omit if using SSM Session Manager only

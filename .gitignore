.env
.env.local
.env.*.local
node_modules/
__pycache__/
.venv/
venv/
dist/
*.pyc
.DS_Store
.docx_extract/
.mypy_cache/
.ruff_cache/
.claude/worktrees/
.claude/launch.json
**/.claude/launch.json

# Test coverage artefacts (generated by pytest-cov)
.coverage
htmlcov/

# SBOM generated locally by check.sh (trivy image scan)
sbom-*.cyclonedx.json

# retire.js vulnerability database — auto-downloaded by check.sh bootstrap;
# gitignored so it stays current without committing a static snapshot.
frontend/retire-jsrepo.json

# Generated OpenAPI spec — produced by check.sh / export-openapi.py, not committed
openapi.json

# Local RSA key pair — never commit private keys
*.pem

# Terraform-generated Lambda zip — rebuilt on every plan/apply
infra-live-edge/terraform/*.zip

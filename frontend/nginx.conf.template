# If an upstream ALB/CloudFront already set X-Forwarded-Proto, forward it as-is.
# Fall back to $scheme (http) for direct connections (local dev, health checks).
map $http_x_forwarded_proto $real_proto {
    ""      $scheme;
    default $http_x_forwarded_proto;
}

server {
    listen 8080;
    listen [::]:8080;
    server_name localhost;
    root /usr/share/nginx/html;
    index index.html;

    gzip on;
    gzip_vary on;
    gzip_comp_level 5;
    gzip_types text/plain text/css application/javascript application/json image/svg+xml application/font-woff2;

    # HSTS must be configured at the TLS-termination layer (ALB / CloudFront response-headers
    # policy). This nginx instance only speaks HTTP — TLS is terminated upstream — so setting
    # HSTS here has no effect on browsers and is misleading. Do not re-add it here.
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Content-Security-Policy "default-src 'self'; script-src 'self' https://accounts.google.com; style-src 'self' 'unsafe-inline' https://accounts.google.com; img-src 'self' data: https://upload.wikimedia.org; font-src 'self' data:; connect-src 'self' https://accounts.google.com; frame-src https://accounts.google.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none';" always;
    add_header Permissions-Policy "microphone=(self), camera=(), geolocation=(), payment=(), usb=(), interest-cohort=()" always;

    # API → FastAPI (browser uses same origin http://HOST:FRONTEND_PORT/api/...)
    location /api/ {
        proxy_pass http://backend:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        # Use the map above: forwards ALB/CloudFront's X-Forwarded-Proto when present,
        # falls back to $scheme for direct connections so the header is never empty.
        proxy_set_header X-Forwarded-Proto $real_proto;
        # Backend LLM_TIMEOUT_SECONDS defaults to 60s; give it margin so nginx
        # does not cut the connection while the backend is still awaiting the LLM.
        proxy_read_timeout 90s;
        proxy_connect_timeout 10s;
        proxy_send_timeout 30s;
    }

    # Vite build output: hashed JS/CSS/fonts — immutable caching.
    location /assets/ {
        expires 1y;
        # Any add_header in a location block disables inheritance of the server-block
        # add_header directives. Re-declare X-Content-Type-Options here so hashed
        # JS/CSS assets are still served with the nosniff protection.
        add_header Cache-Control "public, immutable";
        add_header X-Content-Type-Options "nosniff" always;
        access_log off;
    }

    # Backend S3 assets proxied to the backend S3 bucket.
    # /app-assets/ covers all current and future asset subfolders (e.g. child_activity_game/).
    # Completely separate from /assets/ (Vite build output) — no path conflict.
    # ${BACKEND_BUCKET_NAME} is substituted by envsubst at container start (nginx-start.sh).
    location /app-assets/ {
        proxy_pass https://${BACKEND_BUCKET_NAME}.s3.us-east-1.amazonaws.com;
        proxy_set_header Host ${BACKEND_BUCKET_NAME}.s3.us-east-1.amazonaws.com;
        proxy_ssl_server_name on;
        access_log off;
    }

    location = /manifest.json {
        default_type application/json;
        try_files /manifest.json =404;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}

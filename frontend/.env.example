# Copy to `frontend/.env` for local frontend-only development (without Docker).
# When running via Docker Compose, Vite vars are passed as build args — this file is ignored there.
#
# Google Sign-In: OAuth 2.0 *Web client ID*. Must match GOOGLE_CLIENT_ID in the backend.
# Leave empty to hide the Google Sign-In button on the login page.
VITE_GOOGLE_CLIENT_ID=
#
# API base URL (optional). Leave empty to use the Vite dev-server proxy (/api → localhost:8000).
# Set to a full URL when the API is on a different origin, e.g. https://api.example.com
# VITE_API_URL=
#
# S3 backend assets bucket. When set, the Vite dev-server proxies /assets/*
# to https://<bucket>.s3.us-east-1.amazonaws.com so local dev can load images.
# Requires the bucket to allow public s3:GetObject on the assets/ prefix.
BACKEND_BUCKET_NAME=

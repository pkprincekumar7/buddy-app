# ============================================================
# buddy-app — root .env (Docker Compose)
# ============================================================
# Copy this file to .env and fill in the values.
# This file is read by Docker Compose for ${VAR} substitution.
# For backend-only local dev (no Docker), use backend/.env.example instead.
# ============================================================

# ------------------------------------------------------------
# Exposed host ports (change if defaults clash with other services)
# ------------------------------------------------------------
BACKEND_PORT=8000
FRONTEND_PORT=5173
REDIS_PORT=6379

# ------------------------------------------------------------
# MongoDB — connection string and database name
#
# Docker Compose does NOT include a local MongoDB service.
# Choose one of the options below and set MONGODB_URI accordingly:
#
#   Option A — Atlas (recommended, free M0 tier works for dev):
#     Create a free cluster at https://cloud.mongodb.com, then use:
#     MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true&w=majority
#
#   Option B — Local MongoDB (run separately, not managed by Compose):
#     Install MongoDB Community or run: docker run -p 27017:27017 mongo:7
#     MONGODB_URI=mongodb://localhost:27017
#     Note: localhost inside a Docker container refers to the container itself,
#     not the host. Use host.docker.internal:27017 on Mac/Windows, or
#     start Mongo with --network buddy360_net and reference it by service name.
# ------------------------------------------------------------
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=buddy360-local

# Atlas zone used when no JWT is present (register / login).
# Must match a zone name configured in your Atlas Global Cluster
# (e.g. "us", "eu", "apac" — see GLOBAL_ROUTING_MONGO_ATLAS.md).
DEFAULT_LOCATION=us

# ------------------------------------------------------------
# JWT — required
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Use 64+ hex chars in production.
# ------------------------------------------------------------
JWT_SECRET=
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_HOURS=24

# ------------------------------------------------------------
# LLM providers — set at least one key to enable LLM features.
# Auto-selection priority (first key found wins): OpenAI → Anthropic → Gemini.
# Callers can pin a provider with the `provider` field in POST /api/v1/llm/invoke.
# ------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash

LLM_TIMEOUT_SECONDS=60
LLM_HOURLY_LIMIT=200

# ------------------------------------------------------------
# Google Sign-In — OAuth 2.0 Web client ID
# Leave empty to hide Google button on login and return 503 from POST /auth/google.
# Both values must match (GOOGLE_CLIENT_ID verified by backend, VITE_ baked into frontend image).
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# ------------------------------------------------------------
# Redis — LLM rate limiter
# Default connects to the `redis` Compose service. Override for external Redis.
# Leave blank to fall back to in-process rate limiting (single-instance only).
# ------------------------------------------------------------
REDIS_URL=redis://redis:6379

# ------------------------------------------------------------
# CORS — allowed browser origins (comma-separated, no spaces, no trailing slash)
# ------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080

# ------------------------------------------------------------
# Cookie security for auth tokens (access_token + refresh_token)
# COOKIE_SECURE   — false for local HTTP dev; true in production (HTTPS required).
# COOKIE_SAMESITE — lax suits most SPAs.
# COOKIE_DOMAIN   — leave empty for localhost.
# ------------------------------------------------------------
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# ------------------------------------------------------------
# Application environment
# APP_ENV      — local | prod
# BEHIND_PROXY — true when nginx sits in front of the backend (Docker Compose default).
# ------------------------------------------------------------
APP_ENV=local
BEHIND_PROXY=true

# ------------------------------------------------------------
# S3 — backend assets bucket
# Pre-existing bucket that holds static assets under the app-assets/ prefix.
# Served in production via CloudFront /app-assets/*.
# In local dev with Vite, set this so the dev-server proxy forwards /app-assets
# requests to S3 (requires the bucket to allow public GetObject on app-assets/*).
# Leave empty to skip the proxy (images won't load locally without it).
# ------------------------------------------------------------
ASSETS_BUCKET_NAME=person-local-assets-bucket

# ------------------------------------------------------------
# Frontend Vite build args (Docker Compose passes these at `docker compose build`)
# VITE_API_URL — leave blank so nginx proxies /api → backend on same origin.
# ------------------------------------------------------------
# VITE_API_URL=

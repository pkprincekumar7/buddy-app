# ============================================================
# buddy-app — root .env (Docker Compose)
# ============================================================
# Copy this file to .env and fill in the values.
# This file is read by Docker Compose for ${VAR} substitution.
# For backend-only local dev (no Docker), use backend/.env.example instead.
# ============================================================

# ------------------------------------------------------------
# Exposed host ports (change if defaults clash with other services)
# These control only which port is published on the Docker host for external
# access (e.g. psql GUI, Redis CLI). They do NOT affect container-to-container
# networking — the backend always connects to db:5432 and redis:6379 internally.
# ------------------------------------------------------------
BACKEND_PORT=8000
FRONTEND_PORT=5173
POSTGRES_HOST_PORT=5432
REDIS_PORT=6379

# ------------------------------------------------------------
# PostgreSQL — used by the `db` service and passed to `backend`
# ------------------------------------------------------------
# Docker Compose: service name 'db'.
# AWS (RDS single or multi-region): replace with the RDS endpoint hostname,
#   e.g. buddy360.xxxxxxxxxxxx.eu-west-1.rds.amazonaws.com
POSTGRES_HOST=db
POSTGRES_USER=buddy360
POSTGRES_PASSWORD=buddy360_dev
POSTGRES_DB=buddy360

# Optional: single URL override. Omit when using discrete POSTGRES_* above.
# DATABASE_URL=postgresql+psycopg://buddy360:buddy360_dev@db:5432/buddy360

# DB connection pool (tune for your instance size)
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10

# ------------------------------------------------------------
# JWT — required
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Use 64+ hex chars in production.
# ------------------------------------------------------------
JWT_SECRET=
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_HOURS=24

# ------------------------------------------------------------
# LLM providers — set at least one key to enable LLM features.
# Auto-selection priority (first key found wins): OpenAI → Anthropic → Gemini.
# Callers can pin a provider with the `provider` field in POST /api/v1/llm/invoke.
# ------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Max seconds to wait for an LLM response before timing out
LLM_TIMEOUT_SECONDS=60

# Max LLM calls per user per hour (Redis sliding window).
# Set generously — per-minute slowapi limit handles bursts; this caps sustained cost.
LLM_HOURLY_LIMIT=200

# ------------------------------------------------------------
# Google Sign-In — OAuth 2.0 Web client ID
# Leave empty to hide Google button on login and return 503 from POST /auth/google.
# Both values must match (GOOGLE_CLIENT_ID verified by backend, VITE_ baked into frontend image).
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# ------------------------------------------------------------
# Redis — LLM rate limiter
# Default connects to the `redis` Compose service. Override for external Redis.
# Leave blank to fall back to in-process rate limiting (single-instance only).
# ------------------------------------------------------------
REDIS_URL=redis://redis:6379

# ------------------------------------------------------------
# CORS — allowed browser origins (comma-separated, no spaces, no trailing slash)
# ------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080

# ------------------------------------------------------------
# Cookie security for auth tokens (access_token + refresh_token)
# COOKIE_SECURE   — false for local HTTP dev; true in production (HTTPS required).
# COOKIE_SAMESITE — lax suits most SPAs; strict if you never navigate from external links.
# COOKIE_DOMAIN   — leave empty for localhost. In production set to root domain
#                   (e.g. example.com) only if cookies must span subdomains.
# ------------------------------------------------------------
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# See .env.prod.example for production / AWS values.

# ------------------------------------------------------------
# Application environment
# APP_ENV      — local | prod (prod enforces stricter validation)
# BEHIND_PROXY — true when running via docker-compose: nginx sits in front of the
#                backend and sets X-Forwarded-For, so the backend must read that
#                header to get the real client IP for rate limiting.
#                Set to false only if you run the backend directly without any proxy.
# ------------------------------------------------------------
APP_ENV=local
BEHIND_PROXY=true

# ------------------------------------------------------------
# Multi-region routing (optional — omit for single-instance / local dev)
# ROUTER_DB_URL    — PostgreSQL URL for the Global Router DB (email_hash → region).
#                    Falls back to main DATABASE_URL when not set.
# REGIONAL_DB_URLS — JSON map of region → PostgreSQL URL.
#                    Example: {"eu":"postgresql://...","us":"postgresql://..."}
#                    Falls back to main DATABASE_URL for all regions when not set.
# DEFAULT_REGION   — Region used when no JWT is present (register/login in single-instance mode).
#                    Local dev: "local" (routes to DATABASE_URL).
# ------------------------------------------------------------
DEFAULT_REGION=local
# ROUTER_DB_URL=postgresql+psycopg://user:pass@router-db-host:5432/buddy_router
# REGIONAL_DB_URLS={"eu":"postgresql+psycopg://...","us":"postgresql+psycopg://..."}

# Aurora Global Database (multi-region) — skip migrations on read-only replicas.
# Set these to any non-empty value in secondary-region task definitions.
# Run both migrations once from the primary region before your first deployment.
# REGIONAL_DB_SKIP_MIGRATION=
# ROUTER_DB_URL_SKIP_MIGRATION=

# ------------------------------------------------------------
# Background reconciler — repairs stale saga writes
# How often (minutes) to scan user_regions for 'pending' rows older than 10 min
# and either activate them (user exists) or delete them (user missing).
# ------------------------------------------------------------
RECONCILER_INTERVAL_MINUTES=5

# ------------------------------------------------------------
# Frontend Vite build args (Docker Compose passes these at `docker compose build`)
# VITE_API_URL — leave blank so nginx proxies /api → backend on same origin.
#                Set to full URL when UI and API are on different origins.
# ------------------------------------------------------------
# VITE_API_URL=

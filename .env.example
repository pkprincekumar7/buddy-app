# Copy to `.env` in this folder (Compose reads it automatically for ${VAR} substitution).
#
# Frontend build (Docker): leave VITE_API_URL unset so nginx proxies /api → backend.
# For a separate API hostname: VITE_API_URL=https://api.example.com
#
# Ports (defaults match docker-compose.yml):
BACKEND_PORT=8000
FRONTEND_PORT=5173
#
# Postgres — used by the `db` service and passed into `backend`:
POSTGRES_HOST=db
POSTGRES_USER=buddy360
POSTGRES_PASSWORD=buddy360_dev
POSTGRES_DB=buddy360
POSTGRES_PORT=5432
# Single URL overrides discrete POSTGRES_* (optional; omit in Docker Compose — discrete vars apply):
# DATABASE_URL=
#
# LLM providers — set at least one key to enable LLM features.
# Auto-selection priority (first key found wins): OpenAI → Anthropic → Gemini.
# Callers can also pin a provider with the `provider` field in POST /api/v1/llm/invoke.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
# Required — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
#
# JWT: short-lived access token and longer refresh token (login/register/refresh return both).
# POST /auth/refresh requires both tokens to still be valid; neither may be expired.
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_HOURS=24
#
# Google Sign-In: OAuth 2.0 *Web client ID* (same value for API verification and Vite bundle).
# Leave empty to hide Google on the login page and return 503 from POST /auth/google.
GOOGLE_CLIENT_ID=
# Baked into the frontend image at `docker compose build`; use the same ID as GOOGLE_CLIENT_ID.
VITE_GOOGLE_CLIENT_ID=
#
# Vite (optional): override API base when UI and API are on different origins.
# Leave blank for Docker nginx same-origin /api proxy or local Vite proxy.
# VITE_API_URL=
#
# Allowed browser origins for the FastAPI CORS middleware (comma-separated, no spaces).
# Match your UI URL(s). Docker compose default includes alternate host ports.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080
#
# Cookie security for auth tokens (access_token + refresh_token).
# COOKIE_SECURE   — false for local HTTP dev; true in production (requires HTTPS).
# COOKIE_SAMESITE — lax works for most SPAs; use strict if you never navigate from external links.
# COOKIE_DOMAIN   — leave empty for localhost; in production set to your root domain (e.g. example.com)
#                   only if you need cookies shared across subdomains (api.example.com ↔ app.example.com).
#
# Local dev values:
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
#
# Production values (set these in your secrets manager / deploy pipeline):
# COOKIE_SECURE=true
# COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=example.com
#
# Backend-only local run: see backend/.env.example
# Frontend-only local run: see frontend/.env.example

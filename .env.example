# Copy to `.env` in this folder (Compose reads it automatically for ${VAR} substitution).
#
# Frontend build (Docker): leave VITE_API_URL unset so nginx proxies /api → backend.
# For a separate API hostname: VITE_API_URL=https://api.example.com
#
# Ports (defaults match docker-compose.yml):
BACKEND_PORT=8000
FRONTEND_PORT=5173
#
# Postgres — used by the `db` service and passed into `backend`:
POSTGRES_HOST=db
POSTGRES_USER=buddy360
POSTGRES_PASSWORD=buddy360_dev
POSTGRES_DB=buddy360
POSTGRES_PORT=5432
# Single URL overrides discrete POSTGRES_* (optional; omit in Docker Compose — discrete vars apply):
# DATABASE_URL=
#
# Secrets / model (passed into backend container):
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
JWT_SECRET=change-me-for-production-long-random
#
# Allowed browser origins for the FastAPI CORS middleware (comma-separated, no spaces).
# Match your UI URL(s). Docker compose default includes alternate host ports.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080
#
# Backend: full details in backend/.env.example

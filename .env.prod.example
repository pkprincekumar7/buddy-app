# ============================================================
# buddy-app — .env.prod (AWS / production)
# ============================================================
# Copy this file to .env.prod (or inject via your secrets manager /
# ECS task definition / Parameter Store) and fill in all values.
# NEVER commit the filled-in file to source control.
# ============================================================

# ------------------------------------------------------------
# Exposed ports
# ------------------------------------------------------------
BACKEND_PORT=8000
FRONTEND_PORT=80

# ------------------------------------------------------------
# MongoDB Atlas Global Cluster
# Use the Atlas connection string for the cluster (all zones are reached via this single URI).
# Atlas routes each write to the correct zone automatically based on the `location` shard key.
# ------------------------------------------------------------
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=buddy_app

# Atlas zone used as default when no JWT is present.
# Set to your primary zone (e.g. "us", "eu") — must match an Atlas zone name.
DEFAULT_LOCATION=us

# ------------------------------------------------------------
# JWT — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Use 64+ hex chars in production.
# ------------------------------------------------------------
JWT_SECRET=<64-char-hex-secret>
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_HOURS=24

# ------------------------------------------------------------
# LLM providers — set at least one key.
# Auto-selection priority (first key found wins): OpenAI → Anthropic → Gemini.
# ------------------------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-flash

LLM_TIMEOUT_SECONDS=60
LLM_HOURLY_LIMIT=200

# ------------------------------------------------------------
# Google Sign-In — must match the OAuth 2.0 Web client ID baked into the frontend image
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=<your-google-client-id>.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=<your-google-client-id>.apps.googleusercontent.com

# ------------------------------------------------------------
# Redis — ElastiCache for LLM rate limiting
# ------------------------------------------------------------
REDIS_URL=redis://<elasticache-endpoint>:6379

# ------------------------------------------------------------
# CORS — browser-facing origin(s); no trailing slash, no wildcard
# ------------------------------------------------------------
CORS_ORIGINS=https://yourapp.example.com

# ------------------------------------------------------------
# Cookie security — always use these values in production
# ------------------------------------------------------------
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# ------------------------------------------------------------
# Application environment
# ------------------------------------------------------------
APP_ENV=prod
BEHIND_PROXY=true

# ------------------------------------------------------------
# Frontend Vite build args
# Leave VITE_API_URL blank when UI and API share the same origin (ALB routes /api/*).
# ------------------------------------------------------------
# VITE_API_URL=

# ============================================================
# buddy-app — .env.prod (AWS production)
# ============================================================
# Copy this file to .env.prod (or inject via your secrets manager /
# ECS task definition / Parameter Store) and fill in all values.
# NEVER commit the filled-in file to source control.
# ============================================================

# ------------------------------------------------------------
# Exposed ports (ECS / EC2 — not used by docker-compose in prod)
# POSTGRES_HOST_PORT is the host-side mapping for local dev only; not needed in ECS.
# ------------------------------------------------------------
BACKEND_PORT=8000
FRONTEND_PORT=80

# ------------------------------------------------------------
# PostgreSQL — AWS RDS (single-region) or Aurora (multi-region)
# Option A: single URL (recommended — avoids ambiguity)
# Option B: discrete vars (comment out DATABASE_URL and use these)
# ------------------------------------------------------------

# Single-region RDS example:
DATABASE_URL=postgresql+psycopg://buddy360:<password>@buddy360.<id>.<region>.rds.amazonaws.com:5432/buddy360

# Aurora Global Database (multi-region) — point to the writer endpoint:
# DATABASE_URL=postgresql+psycopg://buddy360:<password>@buddy360-cluster.cluster-<id>.<region>.rds.amazonaws.com:5432/buddy360

# Discrete vars alternative (omit DATABASE_URL if using these):
# POSTGRES_HOST=buddy360.<id>.<region>.rds.amazonaws.com
# POSTGRES_PORT=5432
# POSTGRES_USER=buddy360
# POSTGRES_PASSWORD=<password>
# POSTGRES_DB=buddy360

# DB connection pool — tune for your RDS instance class.
# NOTE (multi-region): total connections per pod =
#   (POSTGRES_POOL_SIZE + POSTGRES_MAX_OVERFLOW) × (num_regional_dbs + 1 router_db)
# Example: 6 regions → (10+20)×7 = 210 connections/pod.
# Reduce pool size if running many pods; size Aurora accordingly (db.r6g.large ≈ 1000 max).
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20

# ------------------------------------------------------------
# JWT — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Use 64+ hex chars in production.
# ------------------------------------------------------------
JWT_SECRET=<64-char-hex-secret>
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_HOURS=24

# ------------------------------------------------------------
# LLM providers — set at least one key.
# Auto-selection priority (first key found wins): OpenAI → Anthropic → Gemini.
# ------------------------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-flash

LLM_TIMEOUT_SECONDS=60
LLM_HOURLY_LIMIT=200

# ------------------------------------------------------------
# Google Sign-In — must match the OAuth 2.0 Web client ID baked into the frontend image
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=<your-google-client-id>.apps.googleusercontent.com
# VITE_GOOGLE_CLIENT_ID is a BUILD-TIME arg, not a runtime env var.
# It is baked into the frontend image at `docker build` time.
# In ECS/CI pipelines pass it via --build-arg or your pipeline's build-step
# environment — setting it only in the ECS task definition has no effect.
VITE_GOOGLE_CLIENT_ID=<your-google-client-id>.apps.googleusercontent.com

# ------------------------------------------------------------
# Redis — ElastiCache (or Redis Cloud) for LLM rate limiting
# ------------------------------------------------------------
REDIS_URL=redis://<elasticache-endpoint>:6379

# ------------------------------------------------------------
# CORS — browser-facing origin(s); no trailing slash, no wildcard
# ------------------------------------------------------------
CORS_ORIGINS=https://yourapp.example.com

# ------------------------------------------------------------
# Cookie security — always use these values in production
# COOKIE_SECURE   — true: cookies only sent over HTTPS (required)
# COOKIE_SAMESITE — lax: allows navigation from external links
# COOKIE_DOMAIN   — set to root domain only if cookies must span subdomains
#                   (e.g. ".example.com" for app.example.com + api.example.com)
#                   Leave blank if UI and API share the same origin.
# ------------------------------------------------------------
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# ------------------------------------------------------------
# Application environment
# BEHIND_PROXY — true: read X-Forwarded-For from ALB for rate limiting
# ------------------------------------------------------------
APP_ENV=prod
BEHIND_PROXY=true

# ------------------------------------------------------------
# Multi-region routing (single-region: leave ROUTER_DB_URL and REGIONAL_DB_URLS blank)
#
# Single-region AWS:
#   DEFAULT_REGION=us          (set to the region code your DATABASE_URL lives in)
#   ROUTER_DB_URL=             (leave blank — uses DATABASE_URL above)
#   REGIONAL_DB_URLS={}        (empty map — all traffic to DATABASE_URL)
#
# Multi-region AWS (Aurora Global Database):
#   ROUTER_DB_URL    — writer endpoint of the Global Router Aurora cluster
#   REGIONAL_DB_URLS — JSON map of region code → regional Aurora reader/writer URL
#   DEFAULT_REGION   — fallback region for unknown country codes; set to your
#                      primary/largest region (e.g. "us" or "eu"), NOT "local"
#
# Example multi-region:
#   ROUTER_DB_URL=postgresql+psycopg://buddy360:<pw>@router-cluster.cluster-<id>.eu-west-1.rds.amazonaws.com:5432/buddy_router
#   REGIONAL_DB_URLS={"eu":"postgresql+psycopg://buddy360:<pw>@eu-cluster.cluster-<id>.eu-west-1.rds.amazonaws.com:5432/buddy360","us":"postgresql+psycopg://buddy360:<pw>@us-cluster.cluster-<id>.us-east-1.rds.amazonaws.com:5432/buddy360"}
# ------------------------------------------------------------
# !! CHANGE THIS in production — "local" routes to DATABASE_URL which is correct
#    for single-instance, but in multi-region set this to your primary region (e.g. "us").
DEFAULT_REGION=us
ROUTER_DB_URL=
# Single-region: leave as empty string or {}.  Multi-region: JSON map of region → DB URL.
# Example: {"eu":"postgresql+psycopg://...","us":"postgresql+psycopg://..."}
REGIONAL_DB_URLS={}

# ------------------------------------------------------------
# Aurora Global Database — skip migrations on read-only secondary replicas.
# Set to any non-empty value in secondary-region ECS task definitions.
# Run both alembic migrations once from the primary region before first deploy.
# ------------------------------------------------------------
# REGIONAL_DB_SKIP_MIGRATION=true
# ROUTER_DB_URL_SKIP_MIGRATION=true

# ------------------------------------------------------------
# Background reconciler — repairs stale saga writes
# ------------------------------------------------------------
RECONCILER_INTERVAL_MINUTES=5

# ------------------------------------------------------------
# Frontend Vite build args
# Leave VITE_API_URL blank when UI and API share the same origin (ALB routes /api/*).
# Set to the full API URL only when UI and API are on different origins.
# ------------------------------------------------------------
# VITE_API_URL=

API_URL=http://localhost:8000
GOOGLE_CLIENT_ID=your-web-oauth-client-id.apps.googleusercontent.com
IOS_CLIENT_ID=your-ios-oauth-client-id.apps.googleusercontent.com
# CDN_BASE_URL — base URL for /app-assets/* (stage splash, activity images, avatars).
# Leave unset in dev: the app auto-detects the running Vite dev server (port 5173).
# Set this for production builds to the deployed web URL or S3/CloudFront base URL.
# CDN_BASE_URL=https://your-production-url.com
